# Auth (Google OAuth)
AUTH_SECRET=  # Generate with: openssl rand -base64 32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Encryption key for API keys stored in DB (set once, never rotate without re-encrypting).
# Generate with: openssl rand -hex 32
APP_ENCRYPTION_KEY=

# Database
DATABASE_URL=postgresql://videoad:password@localhost:5432/videoad
POSTGRES_PASSWORD=change-me-to-a-strong-password

# AI Providers
LUMA_API_KEY=
RUNWAY_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
KLING_API_KEY=
MINIMAX_API_KEY=

# Seedance / BytePlus ModelArk (Volcano Engine AK/SK signature auth)
SEEDANCE_ACCESS_KEY=
SEEDANCE_SECRET_KEY=
SEEDANCE_ENDPOINT_ID=
# Optional overrides (defaults: ap-southeast / ark)
SEEDANCE_REGION=
SEEDANCE_SERVICE=

# UploadThing
UPLOADTHING_TOKEN=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=video-ads
R2_PUBLIC_URL=

# Resend (email verification)
RESEND_API_KEY=

# Inngest (optional in dev)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
